# Copy to ".env" and adjust if the default port is already in use on this box.
# Only the web (nginx) container publishes a host port; the API server is
# reachable only inside the Docker network, so it never collides with the host.

# Host port the web UI is published on (http://localhost:<WEB_PORT>).
WEB_PORT=8080

# --- Optional backend tuning (defaults shown) ---
# DNS_TIMEOUT_MS=5000
# DNS_TRIES=2
# DNS_HOST_CONCURRENCY=8
# DNS_MAX_RETRIES=10
# DNS_BACKOFF_MS=100,500,1000,2000
# SOFT_MAX_RECORDS=150
# MAX_UPLOAD_BYTES=10485760
# MAX_BATCHES=10

# --- DNS resolution mode ---
# By default the checker resolves iteratively FROM THE ROOT servers and queries
# every authoritative nameserver directly (freshest data). This needs outbound
# UDP/TCP :53 to arbitrary IPs. If that is blocked, set the next flag to use the
# local/recursive resolver instead (data may be stale and is not authoritative).
# DNS_FORCE_LOCAL_RESOLVER=false
# Resolver IP(s) for the fallback/forced-local path (comma-separated). Empty =
# the system/container default resolver.
# DNS_FALLBACK_SERVERS=
